# ── Stage 1: Build the React frontend ──────────────────
FROM node:22-alpine AS build-web

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /build
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY web/package.json web/
RUN pnpm install --frozen-lockfile --filter web

COPY web/ web/
RUN pnpm --filter web build

# ── Stage 2: Build the Express server ──────────────────
FROM node:22-alpine AS build-server

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /build
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY server/package.json server/
RUN pnpm install --frozen-lockfile --filter vtms-server

COPY server/ server/
RUN pnpm --filter vtms-server build

# ── Stage 3: Production runtime ────────────────────────
FROM node:22-alpine AS runtime

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app/server

# Install production dependencies only
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml /app/
COPY server/package.json ./
RUN cd /app && pnpm install --frozen-lockfile --filter vtms-server --prod

# Copy compiled server
COPY --from=build-server /build/server/dist ./dist

# Copy frontend build into public/ (served by express.static)
COPY --from=build-web /build/web/dist ./public

# Config data directory (persisted via volume)
RUN mkdir -p /app/server/data
VOLUME ["/app/server/data"]

ENV NODE_ENV=production
ENV PORT=3001
ENV HOST=0.0.0.0

EXPOSE 3001

CMD ["node", "dist/index.js"]
