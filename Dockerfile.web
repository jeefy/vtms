# ── Stage 1: Build the React frontend ──────────────────
FROM node:22-alpine AS build-web

WORKDIR /build/web
COPY web/package.json web/package-lock.json ./
RUN npm ci
COPY web/ ./
RUN npm run build

# ── Stage 2: Build the Express server ──────────────────
FROM node:22-alpine AS build-server

WORKDIR /build/server
COPY server/package.json server/package-lock.json ./
RUN npm ci
COPY server/ ./
RUN npm run build

# ── Stage 3: Production runtime ────────────────────────
FROM node:22-alpine AS runtime

WORKDIR /app/server

# Install production dependencies only
COPY server/package.json server/package-lock.json ./
RUN npm ci --omit=dev && npm cache clean --force

# Copy compiled server
COPY --from=build-server /build/server/dist ./dist

# Copy frontend build into public/ (served by express.static)
COPY --from=build-web /build/web/dist ./public

# Config data directory (persisted via volume)
RUN mkdir -p /app/server/data
VOLUME ["/app/server/data"]

ENV NODE_ENV=production
ENV PORT=3001
ENV HOST=0.0.0.0

EXPOSE 3001

CMD ["node", "dist/index.js"]
