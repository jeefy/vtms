# VTMS secrets — single source of truth
# Copy to .env and fill in real values.  .env is gitignored.

# PostgreSQL
POSTGRES_PASSWORD=changeme

# WiFi networks (ESP32 devices connect to these, tried in order)
# Quote values that contain spaces or special characters
WIFI_SSID_1=vtms
WIFI_PASSWORD_1=changeme
WIFI_SSID_2='MyWiFi'
WIFI_PASSWORD_2='changeme'

# Car-Pi hotspot (Ansible uses these; typically same as WIFI 1)
HOTSPOT_SSID=vtms
HOTSPOT_PASSWORD=changeme

# MQTT broker (all ESP32 devices connect to this)
MQTT_BROKER=192.168.50.24
MQTT_PORT=1883

# OTA server (car-pi Tailscale IP)
OTA_SERVER=100.84.179.100:8266
