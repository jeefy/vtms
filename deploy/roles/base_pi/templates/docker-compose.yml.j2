services:
  vtms-web:
    image: {{ registry }}/vtms-web:latest
    container_name: vtms-web
    restart: always
    network_mode: host
    volumes:
      - vtms-web-data:/app/server/data
    environment:
      - PORT=3001
      - HOST=0.0.0.0
    labels:
      - "com.centurylinklabs.watchtower.enable=true"

  vtms-sdr:
    image: {{ registry }}/vtms-sdr:latest
    container_name: vtms-sdr
    restart: always
    privileged: true
    network_mode: host
    volumes:
      - /dev/bus/usb:/dev/bus/usb
      - vtms-sdr-data:/app/data
    environment:
      - MQTT_BROKER={{ mqtt_broker | default('127.0.0.1') }}
      - MQTT_PREFIX={{ mqtt_prefix | default('lemons/') }}
      - AUDIO_WS_PORT={{ sdr_audio_ws_port | default('9003') }}
    command: >-
      record
      --freq 462.5625M
      --mqtt-broker ${MQTT_BROKER}
      --mqtt-prefix ${MQTT_PREFIX}
      --audio-ws-port ${AUDIO_WS_PORT}
    labels:
      - "com.centurylinklabs.watchtower.enable=true"

  watchtower:
    image: containrrr/watchtower:latest
    container_name: watchtower
    restart: always
    environment:
      - DOCKER_API_VERSION=1.45
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    command: --interval 120 --cleanup
    labels:
      - "com.centurylinklabs.watchtower.enable=false"

volumes:
  vtms-web-data:
  vtms-sdr-data:
